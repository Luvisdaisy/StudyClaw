# DashScope API (LLM Provider)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# GitHub Authentication
GITHUB_TOKEN=your_github_personal_access_token_here


# Database URL
DATABASE_URL=sqlite+aiosqlite:///./studyclaw.db

# Brave Search API (for web search feature)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Redis Configuration (for session persistence)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=studyclaw
POSTGRES_USER=studyclaw
POSTGRES_PASSWORD=your_postgres_password_here

# Session Persistence Configuration
SESSION_BATCH_INTERVAL=60
SESSION_BATCH_SIZE=100
